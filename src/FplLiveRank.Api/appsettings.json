{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=fpllive;Username=fpllive;Password=fpllive"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "KeyPrefix": "fpl:",
    "Enabled": true
  },
  "FplApi": {
    "BaseUrl": "https://fantasy.premierleague.com/api/",
    "UserAgent": "FplLiveRank/1.0",
    "TimeoutSeconds": 15,
    "RetryCount": 3
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  }
}
